{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/play", "destination": "/play.html" },
    { "source": "/worlds", "destination": "/graph.html" },
    { "source": "/you", "destination": "/graph.html" },
    { "source": "/build", "destination": "/world.html" },
    { "source": "/world/:name", "destination": "/world.html" }
  ],
  "headers": [
    {
      "source": "/sdk/(.*)",
      "headers": [{ "key": "cache-control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/(.*)\\.(js|mjs|html)",
      "headers": [{ "key": "cache-control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/world/(.*)",
      "headers": [{ "key": "cache-control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/(build|worlds|you|play)",
      "headers": [{ "key": "cache-control", "value": "public, max-age=0, must-revalidate" }]
    }
  ]
}
