# dependencies
node_modules/

# vercel
.vercel/

# local env / secrets — never commit keys
.env
.env.*
*.local

# editor
.vscode/
.DS_Store

# local key overrides (if you ever keep a real-key copy for `vercel dev`)
config.local.js
dei_config.local.js

# local audio — ignore stray mp3s, but the baked Beat It track SHIPS
# (opted in for the hosted music-sync demo)
assets/audio/*.mp3
!assets/audio/beat-it.mp3

# model weights — stock/downloadable or trained; never commit into the web repo
# (YOLO stack + trained best.pt live in ../yololab, deployed separately)
*.pt
*.onnx
*.engine

# local-only footage samples — never deploy (source-video ToS + size)
clips/
